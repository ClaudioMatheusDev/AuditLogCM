  <PackageTags>audit;efcore;aspnetcore;interceptor;dotnet</PackageTags>
  <RepositoryUrl>https://github.com/ClaudioMatheusDev/AuditLogCM</RepositoryUrl>
  <PackageLicenseExpression>MIT</PackageLicenseExpression>
